  FS_LIST_MARKER (&grub_btrfs_fs);
  cmd_info = COMMAND_LIST_MARKER("btrfs-info", grub_cmd_btrfs_info, "DEVICE", "Print BtrFS info about DEVICE.")
  cmd_mount_subvol = COMMAND_LIST_MARKER("btrfs-mount-subvol", grub_cmd_btrfs_mount_subvol, "DEVICE DIRECTORY SUBVOL", "Set btrfs DEVICE the DIRECTORY a mountpoint of SUBVOL.")
