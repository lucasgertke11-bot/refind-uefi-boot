  cmd_get_default_subvol = EXTCOMMAND_LIST_MARKER("btrfs-get-default-subvol", grub_cmd_btrfs_get_default_subvol, 0, "[-p|-n] [-o var] DEVICE", "Print default BtrFS subvolume on " "DEVICE.", options)
